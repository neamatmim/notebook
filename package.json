{
  "name": "notebook",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@tanstack/react-table": "^8.21.3",
      "@tanstack/react-router": "^1.163.3",
      "dotenv": "^17.3.1",
      "lucide-react": "^0.575.0",
      "react": "19.2.4",
      "sonner": "2.0.7",
      "zod": "^4.3.6",
      "type-fest": "5.4.4",
      "es-toolkit": "1.44.0",
      "vite": "^7.3.1",
      "typescript": "^5",
      "@types/pg": "^8.18.0",
      "@types/react": "19.2.14",
      "@types/node": "^25.3.2",
      "@orpc/server": "^1.13.5",
      "@orpc/client": "^1.13.5",
      "@orpc/openapi": "^1.13.5",
      "@orpc/zod": "^1.13.5",
      "better-auth": "^1.5.4",
      "drizzle-orm": "^0.45.1"
    }
  },
  "type": "module",
  "scripts": {
    "clean": "git clean -xdf node_modules .turbo .vercel",
    "clean:workspaces": "turbo run clean",
    "dev": "turbo dev",
    "build": "turbo build",
    "dev:web": "turbo -F web dev",
    "build:web": "turbo -F web build",
    "start:web": "turbo -F web start",
    "db:push": "turbo -F @notebook/db db:push",
    "db:studio": "turbo -F @notebook/db db:studio",
    "db:generate": "turbo -F @notebook/db db:generate",
    "db:migrate": "turbo -F @notebook/db db:migrate",
    "db:start": "turbo -F @notebook/db db:start",
    "db:watch": "turbo -F @notebook/db db:watch",
    "db:stop": "turbo -F @notebook/db db:stop",
    "db:down": "turbo -F @notebook/db db:down",
    "prepare": "husky",
    "ruler:apply": "bunx @intellectronica/ruler@latest apply --local-only"
  },
  "dependencies": {
    "nitro": "npm:nitro-nightly@latest"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "husky": "latest",
    "lint-staged": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "turbo": "latest",
    "typescript": "catalog:",
    "ultracite": "7.2.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "bun x ultracite fix"
    ]
  },
  "packageManager": "bun@1.3.8"
}
